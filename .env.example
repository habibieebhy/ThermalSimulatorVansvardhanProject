# ---------------------------------------------------------
# CORE MODE
# ---------------------------------------------------------

CELERY_ENABLED=true
CELERY_ALWAYS_EAGER=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT_SECONDS=7200
CELERY_WAIT_TIMEOUT_SECONDS=7200
CELERY_RESULT_EXPIRES_SECONDS=3600

MATTRESS_INTEL_LLM_PROVIDER=openai
MATTRESS_INTEL_SEARCH_PROVIDER=services
MATTRESS_INTEL_CAPTURE_STRATEGY=services_first

# ---------------------------------------------------------
# OPENAI
# ---------------------------------------------------------

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# ---------------------------------------------------------
# SEARCH AND PAGE ACQUISITION
# ---------------------------------------------------------

JINA_API_KEY=hehe
FIRECRAWL_API_KEY=hehe

MATTRESS_INTEL_JINA_READER_ENABLED=true
MATTRESS_INTEL_JINA_READER_ON_THIN_PAGE=true
MATTRESS_INTEL_JINA_READER_MIN_CHARACTERS=800
MATTRESS_INTEL_JINA_TIMEOUT_SECONDS=60

MATTRESS_INTEL_FIRECRAWL_ENABLED=true
MATTRESS_INTEL_FIRECRAWL_TIMEOUT_SECONDS=60
MATTRESS_INTEL_FIRECRAWL_WAIT_MS=1500

# ---------------------------------------------------------
# LOCAL STORAGE
# ---------------------------------------------------------

DATABASE_URL=
DATABASE_DIRECT_URL=

MATTRESS_INTEL_DATABASE_PATH=./data/mattress_intelligence.sqlite3
MATTRESS_INTEL_JOB_DATABASE_PATH=./data/research_jobs.sqlite3
MATTRESS_INTEL_DATA_DIR=./data
MATTRESS_INTEL_OUTPUT_DIR=./outputs
MATTRESS_INTEL_ARTIFACT_DIR=./artifacts
MATTRESS_INTEL_UI_HISTORY_LIMIT=50
MATTRESS_INTEL_UI_QUEUE_WARNING_SECONDS=90

# ---------------------------------------------------------
# ASSET DISCOVERY AND OCR
# ---------------------------------------------------------

MATTRESS_INTEL_DISCOVER_ASSETS=true
MATTRESS_INTEL_LOCAL_OCR_ENABLED=true

MATTRESS_INTEL_MAX_ASSETS_PER_DOCUMENT=20
MATTRESS_INTEL_MAX_VISION_ASSETS_PER_RUN=15
MATTRESS_INTEL_MAX_PDF_PAGES=80
MATTRESS_INTEL_MINIMUM_ASSET_SCORE=0.28
MATTRESS_INTEL_MAX_IMAGE_BYTES=12000000

MATTRESS_INTEL_OCR_MIN_CHARACTERS=24
TESSERACT_CMD=

# ---------------------------------------------------------
# HTTP AND CRAWLING
# ---------------------------------------------------------

MATTRESS_INTEL_USER_AGENT=BRIXTA-Mattress-Intelligence/1.4
MATTRESS_INTEL_REQUEST_TIMEOUT_SECONDS=30
MATTRESS_INTEL_REQUEST_DELAY_SECONDS=1.0
MATTRESS_INTEL_MAX_DOWNLOAD_BYTES=25000000
MATTRESS_INTEL_RENDER_JAVASCRIPT=true

# ---------------------------------------------------------
# SEARCH LIMITS
# ---------------------------------------------------------

MATTRESS_INTEL_SEARCH_QUERIES=6
MATTRESS_INTEL_SEARCH_RESULTS_PER_QUERY=10

# ---------------------------------------------------------
# RECOGNITION THRESHOLDS
# ---------------------------------------------------------

MATTRESS_INTEL_PRODUCT_RECOGNITION_THRESHOLD=0.68
MATTRESS_INTEL_VISION_RECOGNITION_THRESHOLD=0.62

# ---------------------------------------------------------
# OPTIONAL SERVICES DISABLED
# ---------------------------------------------------------

MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_SECURE=false